// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  COUNSELLOR
  ADMIN
}

enum ResourceType {
  VIDEO
  AUDIO
  GUIDE
}

enum ResourceCategory {
  ANXIETY
  FOCUS
  SLEEP
  MINDFULNESS
  GENERAL
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

// ============================================================
// NextAuth.js v5 required models
// ============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// Application models
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(STUDENT)
  createdAt     DateTime  @default(now())

  counsellorProfile  Counsellor? @relation("UserToCounsellor")

  accounts           Account[]
  sessions           Session[]
  forumTopics        ForumTopic[]
  moodLogs           MoodLog[]
  studentBookings    Booking[]      @relation("StudentBookings")
  counsellorBookings Booking[]      @relation("CounsellorBookings")
  therapyBookings    TherapyBooking[] @relation("TherapyBookingsAsStudent")

  conversations      Conversation[] @relation("ConversationsAsStudent")
  sentMessages       Message[]      @relation("SentMessagesAsStudent")
}

model Resource {
  id           String           @id @default(cuid())
  title        String
  description  String?          @db.Text
  type         ResourceType
  category     ResourceCategory @default(GENERAL)
  url          String           // YouTube embed ID or external link
  thumbnailUrl String?
  duration     String?          // e.g. "5 min", "12 min read"
  isFeatured   Boolean          @default(false)
  createdAt    DateTime         @default(now())
}

model ForumTopic {
  id        String   @id @default(cuid())
  authorId  String
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())
  likes     Int      @default(0)

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Booking {
  id              String        @id @default(cuid())
  studentId       String
  counsellorId    String
  appointmentTime DateTime
  status          BookingStatus @default(PENDING)
  notes           String?       @db.Text
  createdAt       DateTime      @default(now())

  student    User @relation("StudentBookings", fields: [studentId], references: [id], onDelete: Cascade)
  counsellor User @relation("CounsellorBookings", fields: [counsellorId], references: [id], onDelete: Cascade)
}

model MoodLog {
  id          String   @id @default(cuid())
  userId      String
  moodScore   Int      // 1-10 scale (1=very low, 10=excellent)
  stressScore Int?     // 0-100 AI-calculated stress score
  notes       String?  @db.Text
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================
// Peer Forum Messaging models
// ============================================================

enum ConversationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model Conversation {
  id             String             @id @default(cuid())
  studentId      String
  counsellorId   String
  status         ConversationStatus @default(PENDING)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  student        User       @relation("ConversationsAsStudent", fields: [studentId], references: [id], onDelete: Cascade)
  counsellor     Counsellor @relation("ConversationsAsCounsellor", fields: [counsellorId], references: [id], onDelete: Cascade)
  messages       Message[]

  @@unique([studentId, counsellorId])
}

model Message {
  id                 String   @id @default(cuid())
  conversationId     String
  senderStudentId    String?
  senderCounsellorId String?
  content            String   @db.Text
  isRead             Boolean  @default(false)
  createdAt          DateTime @default(now())

  conversation       Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderStudent      User?        @relation("SentMessagesAsStudent", fields: [senderStudentId], references: [id], onDelete: Cascade)
  senderCounsellor   Counsellor?  @relation("SentMessagesAsCounsellor", fields: [senderCounsellorId], references: [id], onDelete: Cascade)
}

// ============================================================
// Therapist Discovery & Booking models
// ============================================================

enum Specialty {
  STRESS
  ANXIETY
  DEPRESSION
  SLEEP
  RELATIONSHIPS
  ACADEMIC
  GENERAL
}

model Counsellor {
  id             String    @id @default(cuid())
  name           String
  bio            String    @db.Text
  specialty      Specialty @default(GENERAL)
  qualifications String    @db.Text
  philosophy     String    @db.Text
  videoUrl       String?
  avatarUrl      String?
  rating         Float     @default(5.0)
  yearsExp       Int       @default(1)
  createdAt      DateTime  @default(now())

  userId         String?   @unique
  user           User?     @relation("UserToCounsellor", fields: [userId], references: [id])

  availability  TherapistAvailability[]
  testimonials  Testimonial[]
  bookings      TherapyBooking[]
  conversations Conversation[] @relation("ConversationsAsCounsellor")
  sentMessages  Message[]      @relation("SentMessagesAsCounsellor")
}

model TherapistAvailability {
  id           String @id @default(cuid())
  counsellorId String
  dayOfWeek    Int    // 0=Sun 1=Mon ... 6=Sat
  startHour    Int    // 9 = 09:00
  endHour      Int    // 17 = 17:00 (45-min slots generated at runtime)

  counsellor Counsellor @relation(fields: [counsellorId], references: [id], onDelete: Cascade)
}

model Testimonial {
  id           String @id @default(cuid())
  counsellorId String
  studentName  String
  text         String @db.Text
  rating       Int    @default(5)

  counsellor Counsellor @relation(fields: [counsellorId], references: [id], onDelete: Cascade)
}

model TherapyBooking {
  id              String        @id @default(cuid())
  studentId       String
  counsellorId    String
  appointmentTime DateTime
  status          BookingStatus @default(PENDING)
  studentNotes    String?       @db.Text
  createdAt       DateTime      @default(now())

  student    User       @relation("TherapyBookingsAsStudent", fields: [studentId], references: [id], onDelete: Cascade)
  counsellor Counsellor @relation(fields: [counsellorId], references: [id], onDelete: Cascade)
}
